      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": [
            "RAG stands for **Retrieval-Augmented Generation**. It is a method that enhances the performance of large language models (LLMs) by combining pre-trained knowledge with real-time information retrieval.\n",
            "\n",
            "### How RAG Works:\n",
            "1. **Knowledge Retrieval**: The model first searches a retrieval system (like a database or external knowledge base) for relevant information.\n",
            "2. **Context Integration**: The retrieved information is then augmented with the context of the user's query.\n",
            "\n"
          ]
        }
      ],
      "source": [
        "messages = [{\"role\":\"user\" , \"content\":\"what is RAG\"}]\n",
        "\n",
        "response = client.chat.completions.create(\n",
        "    model =  FREE_MODEL,\n",
        "    messages = messages,\n",
        "    temperature = 0.8,\n",
        "    max_tokens = 100\n",
        ")\n",
        "\n",
        "text = response.choices[0].message.content\n",
        "print(text)\n",
        "\n"
      ]
    },
