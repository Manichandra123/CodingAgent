      "source": [
        "import json\n",
        "import re\n",
        "import os\n",
        "\n",
        "\n",
        "\n",
        "#  CLEAN JSON FUNCTION\n",
        "def clean_json(text):\n",
        "    if not text:\n",
        "        return None\n",
        "    text = text.strip()\n",
        "    text = re.sub(r\"```json|```\", \"\", text)\n",
        "    return text.strip()\n",
        "\n",
        "\n",
        "\n",
        "# SAFE JSON PARSE\n",
        "def safe_parse(text):\n",
        "    text = clean_json(text)\n",
        "    try:\n",
        "        return json.loads(text)\n",
        "    except:\n",
        "        return None\n",
        "\n",
        "\n",
        "\n",
        "# 🤖 FINAL AGENT LOOP\n",
        "def run_agent(user_query, max_steps=8):\n",
        "\n",
        "    print(\"📁 Working Dir:\", os.getcwd())\n",
        "\n",
        "    messages = [\n",
        "        {\"role\": \"system\", \"content\": SYSTEM_PROMPT},\n",
        "        {\"role\": \"user\", \"content\": user_query}\n",
        "    ]\n",
        "\n",
        "    for step in range(max_steps):\n",
        "\n",
        "        response = client.chat.completions.create(\n",
        "            model=FREE_MODEL,\n",
        "            messages=messages,\n",
        "            temperature=0.1,\n",
        "            max_tokens=400,\n",
        "        )\n",
        "\n",
        "        text = response.choices[0].message.content\n",
        "\n",
        "        print(f\"\\n🔹 Step {step} RAW OUTPUT:\\n{text}\\n\")\n",
        "\n",
        "        data = safe_parse(text)\n",
        "\n",
        "\n",
        "        # JSON ERROR HANDLING\n",
        "\n",
        "        if data is None:\n",
        "            return f\" JSON Parse Failed:\\n{text}\"\n",
        "\n",
        "\n",
        "        # PLAN\n",
        "        if data.get(\"type\") == \"plan\":\n",
        "            print(\"PLAN:\", data.get(\"steps\"))\n",
        "            messages.append({\"role\": \"assistant\", \"content\": json.dumps(data)})\n",
        "            continue\n",
        "\n",
        "        # TOOL CALL\n",
        "        if data.get(\"type\") in [\"action\", \"tool_call\"] or data.get(\"tool\"):\n",
        "\n",
        "            tool_name = data.get(\"tool\")\n",
        "            tool_input_dict = data.get(\"input\", {})\n",
        "\n",
        "            # accept filename OR path\n",
        "            if \"filename\" in tool_input_dict and \"path\" not in tool_input_dict:\n",
        "                tool_input_dict[\"path\"] = tool_input_dict[\"filename\"]\n",
        "\n",
        "            tool_input = json.dumps(tool_input_dict)\n",
        "\n",
        "            print(f\" Running Tool: {tool_name}\")\n",
        "            print(f\"Input: {tool_input}\")\n",
        "\n",
        "            # Unknown tool handling\n",
        "            if tool_name not in TOOLS or \"func\" not in TOOLS[tool_name]:\n",
        "                result = json.dumps({\n",
        "                    \"error\": f\"Unknown tool: {tool_name}\"\n",
        "                })\n",
        "            else:\n",
        "                try:\n",
        "                    result = TOOLS[tool_name][\"func\"](tool_input)\n",
        "                except Exception as e:\n",
        "                    result = json.dumps({\"error\": str(e)})\n",
        "\n",
        "            print(\"TOOL RESULT:\", result)\n",
        "\n",
        "            messages.append({\"role\": \"assistant\", \"content\": json.dumps(data)})\n",
        "            messages.append({\"role\": \"user\", \"content\": f\"OBSERVATION: {result}\"})\n",
        "\n",
        "            continue\n",
        "\n",
        "\n",
        "        # FINAL ANSWER\n",
        "        if data.get(\"type\") == \"final\":\n",
        "            return data.get(\"answer\", \"\")\n",
        "\n",
        "\n",
        "        # FALLBACK\n",
        "        return f\"Unexpected Output:\\n{text}\"\n",
        "\n",
        "    return \"Agent stopped without final answer\""
      ]
    },
