        "import json\n",
        "import os\n",
        "\n",
        "def read_file(input_data):\n",
        "    \"\"\"\n",
        "    Read file content.\n",
        "\n",
        "    Expected input (JSON string):\n",
        "    {\n",
        "        \"path\": \"project/index.html\"\n",
        "    }\n",
        "    \"\"\"\n",
        "\n",
        "    try:\n",
        "        data = json.loads(input_data)\n",
        "        path = data.get(\"path\") or data.get(\"filename\")\n",
        "\n",
        "        if not path:\n",
        "            return json.dumps({\"error\": \"Missing file path\"})\n",
        "\n",
        "        if not os.path.exists(path):\n",
        "            return json.dumps({\"error\": f\"File not found: {path}\"})\n",
        "\n",
        "        with open(path, \"r\", encoding=\"utf-8\") as f:\n",
        "            content = f.read()\n",
        "\n",
        "        return json.dumps({\n",
        "            \"status\": \"success\",\n",
        "            \"path\": path,\n",
        "            \"content\": content[:5000]  # limit to avoid huge tokens\n",
        "        })\n",
        "\n",
        "    except Exception as e:\n",
        "        return json.dumps({\n",
        "            \"error\": str(e)\n",
        "        })\n",
        "\n",
        "\n",
        "def write_file(input_data):\n",
        "    \"\"\"\n",
        "    Write or overwrite a file.\n",
        "\n",
        "    Expected input (JSON string):\n",
        "    {\n",
        "        \"path\": \"project/index.html\",\n",
        "        \"content\": \"<html>...</html>\"\n",
        "    }\n",
        "    \"\"\"\n",
        "\n",
        "    try:\n",
        "        # Parse input\n",
        "        data = json.loads(input_data)\n",
        "\n",
        "        path = data.get(\"path\")\n",
        "        content = data.get(\"content\", \"\")\n",
        "\n",
        "        if not path:\n",
        "            return json.dumps({\"error\": \"Missing file path\"})\n",
        "\n",
        "        # Ensure directory exists\n",
        "        directory = os.path.dirname(path)\n",
        "        if directory:\n",
        "            os.makedirs(directory, exist_ok=True)\n",
        "\n",
        "        # Write file (overwrite mode)\n",
        "        with open(path, \"w\", encoding=\"utf-8\") as f:\n",
        "            f.write(content)\n",
        "\n",
        "        return json.dumps({\n",
        "            \"status\": \"success\",\n",
        "            \"path\": path,\n",
        "            \"bytes_written\": len(content)\n",
        "        })\n",
        "\n",
        "    except Exception as e:\n",
        "        return json.dumps({\n",
        "            \"error\": str(e)\n",
        "        })\n",
        "\n",
        "\n",
        "def update_file(input_data):\n",
        "  try:\n",
        "    #parse\n",
        "    data = json.loads(input_data)\n",
        "    path = data.get(\"path\")\n",
        "    content = data.get(\"content\", \"\")\n",
        "    if not path:\n",
        "      return json.dumps({\"error\": \"Missing file path\"})\n",
        "    # Write file (overwrite mode)\n",
        "    with open(path, \"a\", encoding=\"utf-8\") as f:\n",
        "      f.write(content)\n",
        "    return json.dumps({\n",
        "        \"status\": \"success\",\n",
        "        \"path\": path,\n",
        "        \"bytes_written\": len(content)\n",
        "    })\n",
        "  except Exception as e:\n",
        "    return json.dumps({\n",
        "        \"error\": str(e)\n",
        "    })\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n",
        "\n"
      ]
    },
