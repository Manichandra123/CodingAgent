        "import json\n",
        "import subprocess\n",
        "import tempfile\n",
        "import os\n",
        "\n",
        "def run_code(input_data):\n",
        "    \"\"\"\n",
        "    Run code in different languages.\n",
        "\n",
        "    Input:\n",
        "    {\n",
        "        \"language\": \"python/js/cpp\",\n",
        "        \"code\": \"...\",\n",
        "        \"filename\": \"optional\"\n",
        "    }\n",
        "    \"\"\"\n",
        "\n",
        "    try:\n",
        "        data = json.loads(input_data)\n",
        "\n",
        "        language = data.get(\"language\")\n",
        "        code = data.get(\"code\")\n",
        "        path = data.get(\"path\") or data.get(\"filename\")\n",
        "\n",
        "        if not language or not code:\n",
        "            return json.dumps({\"error\": \"Missing language or code\"})\n",
        "\n",
        "        # Create temp file if not provided\n",
        "        if not filename:\n",
        "            ext_map = {\n",
        "                \"python\": \".py\",\n",
        "                \"javascript\": \".js\",\n",
        "                \"cpp\": \".cpp\"\n",
        "            }\n",
        "            ext = ext_map.get(language, \".txt\")\n",
        "\n",
        "            temp_file = tempfile.NamedTemporaryFile(delete=False, suffix=ext)\n",
        "            temp_file.write(code.encode())\n",
        "            temp_file.close()\n",
        "\n",
        "            filename = temp_file.name\n",
        "\n",
        "        # Run based on language\n",
        "        if language == \"python\":\n",
        "            cmd = [\"python\", filename]\n",
        "\n",
        "        elif language == \"javascript\":\n",
        "            cmd = [\"node\", filename]\n",
        "\n",
        "        elif language == \"cpp\":\n",
        "            exe_file = filename.replace(\".cpp\", \"\")\n",
        "            compile_cmd = [\"g++\", filename, \"-o\", exe_file]\n",
        "            subprocess.run(compile_cmd, capture_output=True)\n",
        "            cmd = [exe_file]\n",
        "        elif language == \"java\":\n",
        "            cmd = [\"java\", filename]\n",
        "\n",
        "        else:\n",
        "            return json.dumps({\"error\": f\"Unsupported language: {language}\"})\n",
        "\n",
        "        result = subprocess.run(cmd, capture_output=True, text=True)\n",
        "\n",
        "        return json.dumps({\n",
        "            \"status\": \"success\",\n",
        "            \"output\": result.stdout,\n",
        "            \"error\": result.stderr\n",
        "        })\n",
        "\n",
        "    except Exception as e:\n",
        "        return json.dumps({\n",
        "            \"error\": str(e)\n",
        "        })"
      ]
    },
